getByTarget:
SELECT * FROM DetailNote
WHERE targetType = ? AND targetId = ? AND authorId = ?;

upsert:
INSERT OR REPLACE INTO DetailNote(
    targetType, targetId, authorId, content, createdAt, updatedAt
) VALUES (?, ?, ?, ?, ?, ?);

deleteByTarget:
DELETE FROM DetailNote
WHERE targetType = ? AND targetId = ? AND authorId = ?;
